---
import FaqSection from "./FaqSection.astro";
import FeaturesWithPanel from "./features-with-panel.tsx";
import FlowSection from "./FlowSection.astro";
import HeroSection from "./HeroSection.astro";
import LandingFooter from "./LandingFooter.astro";
import LandingHeader from "./LandingHeader.astro";
import PricingSection from "./PricingSection.astro";
import ProblemSection from "./ProblemSection.astro";
import ScreenSplitSection from "./ScreenSplitSection.astro";
import ScrollTextSection from "./ScrollTextSection.astro";
import WaitlistSection from "./WaitlistSection.astro";

type Locale = "es" | "en";


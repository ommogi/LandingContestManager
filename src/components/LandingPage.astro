---
import CookieConsent from "./CookieConsent.astro";
import FaqSection from "./FaqSection.astro";
import FeaturesWithPanel from "./features-with-panel.tsx";
import FlowPanelsSection from "./FlowPanelsSection.astro";
import HeroSection from "./HeroSection.astro";
import LandingFooter from "./LandingFooter.astro";
import LandingHeader from "./LandingHeader.astro";
import PricingSection from "./PricingSection.astro";
import ProblemSection from "./ProblemSection.astro";
import ScreenSplitSection from "./ScreenSplitSection.astro";
import WaitlistSection from "./WaitlistSection.astro";
import 'animate.css';

---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ContestManager | Concursos musicales sin Excel</title>
    <link rel="icon" type="image/svg+xml" href="/contestmanager-logo.svg" />
    <link rel="icon" type="image/png" href="/contest-manager-logo.png" />
    <meta name="description" content="ContestManager ayuda a organizaciones musicales a gestionar concursos, rondas, jurados, participantes, ensayos y actuaciones sin depender de Excel." />
    <link rel="canonical" href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Figtree:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <div class="cursor-dot" aria-hidden="true"></div>

    <LandingHeader />

    <main>
      <HeroSection />
      <ProblemSection />
      <section class="section-pad features" style={{
        background: "radial-gradient(125% 125% at 50% 10%, #000000 40%, #0d1a36 100%)",
      }}>
        <h2 class="section-title features-section-title centered">
          Todo lo que necesita una organización musical para competir sin <span class="features-highlight">caos</span>.
        </h2>
        <FeaturesWithPanel client:only="react" />
      </section>
      <ScreenSplitSection
        section={{ label: "Categorías", title: "Estructura el concurso exactamente como lo necesitas.", body: "Crea categorías por modalidad, edad o nivel. Cada una tiene sus propias rondas, jurados asignados y participantes inscritos. Sin mezclas ni confusión." }}
        imageSrc="/mockups/Creacion_concurso.mov"
        imageAlt="Creación de concurso"
        cta="Entrar en lista blanca"
        isVideo
      />
      <ScreenSplitSection
        section={{ label: "Jurados y puntuaciones", title: "Las notas, bajo control desde el primer ensayo.", body: "Asigna jurados por categoría, introduce puntuaciones y consulta medias en tiempo real. Cada ajuste queda registrado para mantener la transparencia durante todo el concurso." }}
        imageSrc="/mockups/Control_notas.mov"
        imageAlt="Control de notas"
        reverse
        cta="Entrar en lista blanca"
        isVideo
      />
      <FlowPanelsSection />
      <ScreenSplitSection
        section={{ label: "Auditoría", title: "Modificar una nota no debería significar perder confianza.", body: "El administrador puede ajustar puntuaciones y medias cuando sea necesario, pero los cambios quedan guardados para saber qué se modificó y mantener transparencia durante el concurso." }}
        imageSrc="/screens/audit.svg"
        imageAlt="Audit trail placeholder"
        cta="Entrar en lista blanca"
      />
      <ScreenSplitSection
        section={{ label: "Calendario", title: "Ensayos y actuaciones, visibles en un solo lugar.", body: "Cada ronda puede tener sus propios ensayos y actuaciones, con hora y ubicación. El organizador ve el calendario completo sin cruzar hojas de cálculo ni mensajes sueltos." }}
        imageSrc="/screens/calendar.svg"
        imageAlt="Calendar placeholder"
        reverse
        cta="Entrar en lista blanca"
      />
      <PricingSection />
      <FaqSection />
      <WaitlistSection />
    </main>

    <LandingFooter />

    <CookieConsent />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { CustomEase } from "gsap/CustomEase";
      import { SplitText } from "gsap/SplitText";
      import Lenis from "lenis";

      gsap.registerPlugin(ScrollTrigger, CustomEase, SplitText);

      // spring-scale-in: cubic-bezier(0.34, 1.56, 0.64, 1) — y2>1 = spring overshoot
      CustomEase.create("springScaleIn", "M0,0 C0.34,1.56,0.64,1,1,1");

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      // ── Animated anchor scroll (GSAP-style via Lenis) ────────────────────────
      document.addEventListener("click", (e) => {
        const anchor = (e.target as Element).closest('a[href^="#"]');
        if (!anchor) return;

        const href = anchor.getAttribute("href");
        if (!href || href === "#") return;

        const target = document.querySelector(href);
        if (!target) return;

        e.preventDefault();

        lenis.scrollTo(target as HTMLElement, {
          offset: -72,
          duration: 1.4,
          easing: (t: number) =>
            t < 0.5
              ? 8 * t * t * t * t
              : 1 - Math.pow(-2 * t + 2, 4) / 2,
        });

        gsap.fromTo(
          target,
          { boxShadow: "inset 0 0 0px rgba(184,255,122,0)" },
          {
            boxShadow: "inset 0 0 60px rgba(184,255,122,0.08)",
            duration: 0.4,
            ease: "power2.out",
            yoyo: true,
            repeat: 1,
          }
        );
      });

      window.addEventListener("load", () => {
        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

        if (!reducedMotion) {
          // ── Cursor glow dot ──────────────────────────────────────────
          const cursorDot = document.querySelector(".cursor-dot");
          if (cursorDot) {
            window.addEventListener("mousemove", (e) => {
              gsap.to(cursorDot, {
                x: e.clientX,
                y: e.clientY,
                duration: 0.18,
                ease: "power2.out",
              });
            });
            document.addEventListener("mouseleave", () => {
              gsap.to(cursorDot, { opacity: 0, duration: 0.2 });
            });
            document.addEventListener("mouseenter", () => {
              gsap.to(cursorDot, { opacity: 1, duration: 0.2 });
            });
          }

          // ── Hero title: spring-scale-in per-word ─────────────────────
          // Word spans are React-rendered by HeroTitle.tsx — no DOM mutation.
          gsap.set(".hero-title", { opacity: 1 });
          gsap.fromTo(
            ".hero-title .text-animation-unit",
            { opacity: 0, scale: 0.7 },
            {
              opacity: 1,
              scale: 1,
              duration: 0.35,
              ease: "springScaleIn",
              stagger: 0.08,
              delay: 0.5,
            },
          );

          // ── Hero: entrance timeline (other elements) ──────────────────
          const heroTl = gsap.timeline({ delay: 0.15 });
          heroTl
            .fromTo(
              ".eyebrow",
              { x: -28, opacity: 0 },
              { x: 0, opacity: 1, duration: 0.55, ease: "power3.out" },
            )
            .to({}, { duration: 0.95 }, "-=0.2") // ghost slot — hero-title handled above
            .fromTo(
              ".hero-body",
              { y: 28, opacity: 0, filter: "blur(5px)" },
              { y: 0, opacity: 1, filter: "blur(0px)", duration: 0.65, ease: "power2.out" },
              "-=0.55",
            )
            .fromTo(
              ".hero-actions",
              { y: 20, opacity: 0, scale: 0.96 },
              { y: 0, opacity: 1, scale: 1, duration: 0.5, ease: "back.out(1.7)" },
              "-=0.45",
            )
            .fromTo(
              ".discount-note",
              { y: 12, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.4, ease: "power2.out" },
              "-=0.35",
            );

          // ── Hero device mockups ───────────────────────────────────────
          const deviceEntrances = [
            { x: -24, y: 48, rotate: -2.5 },
            { x: 0, y: 64, scale: 0.96 },
            { x: 24, y: 48, rotate: 2.5 },
          ];
          const devices = document.querySelectorAll(".device-mockup");
          devices.forEach((device, i) => {
            const from = deviceEntrances[i] ?? { y: 40 };
            gsap.fromTo(
              device,
              { ...from, opacity: 0 },
              {
                x: 0, y: 0, rotate: 0, scale: 1, opacity: 1,
                duration: 1.0,
                delay: 0.55 + i * 0.12,
                ease: "power3.out",
              },
            );

            const direction = i === 0 ? -1 : i === 2 ? 1 : 0;
            gsap.to(device, {
              y: `+=${direction * 22}`,
              scrollTrigger: {
                trigger: ".hero",
                start: "top top",
                end: "bottom top",
                scrub: true,
              },
            });
          });

          // ── Problem: header reveals (eyebrow + body, not title) ──────
          gsap.fromTo(
            ".problem-header .reveal",
            { y: 20, opacity: 0 },
            {
              y: 0, opacity: 1,
              duration: 0.5, stagger: 0.07, ease: "power2.out",
              scrollTrigger: { trigger: ".problem-header", start: "top 85%" },
            },
          );


          gsap.fromTo(
            ".glass-card",
            { y: 44, opacity: 0, scale: 0.95 },
            {
              y: 0, opacity: 1, scale: 1,
              duration: 0.55, stagger: 0.1, ease: "power3.out",
              scrollTrigger: { trigger: ".problem-cards", start: "top 82%" },
            },
          );

          // ── ScreenSplit: copy slides in, media clip-path reveal ───────
          document.querySelectorAll(".feature-split").forEach((split) => {
            const isReverse = split.hasAttribute("data-reverse");
            const copy = split.querySelector("[data-split-copy]");
            const media = split.querySelector("[data-split-media]");

            if (copy) {
              gsap.fromTo(
                copy.querySelectorAll(".reveal"),
                { x: isReverse ? 44 : -44, opacity: 0 },
                {
                  x: 0, opacity: 1,
                  duration: 0.65, stagger: 0.09, ease: "power3.out",
                  scrollTrigger: { trigger: copy, start: "top 82%" },
                },
              );
            }

            if (media) {
              const clipStart = isReverse ? "inset(0 0% 0 100%)" : "inset(0 100% 0 0%)";
              gsap.fromTo(
                media,
                { clipPath: clipStart, opacity: 0.4 },
                {
                  clipPath: "inset(0 0% 0 0%)",
                  opacity: 1,
                  duration: 0.9,
                  ease: "power3.inOut",
                  scrollTrigger: { trigger: media, start: "top 85%" },
                },
              );
            }
          });

          // ── Flow section ──────────────────────────────────────────────
          gsap.fromTo(
            ".flow-header .reveal",
            { y: 24, opacity: 0 },
            {
              y: 0, opacity: 1,
              duration: 0.5, stagger: 0.08, ease: "power2.out",
              scrollTrigger: { trigger: ".flow-header", start: "top 85%" },
            },
          );
          gsap.fromTo(
            ".flow-cards-wrapper",
            { y: 36, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.6, ease: "power2.out",
              scrollTrigger: { trigger: ".flow-cards-wrapper", start: "top 88%" },
            },
          );

          // ── Pricing cards: stagger scale-up ───────────────────────────
          gsap.fromTo(
            ".pricing .section-title",
            { y: 24, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.55, ease: "power2.out",
              scrollTrigger: { trigger: ".pricing", start: "top 85%" },
            },
          );
          gsap.fromTo(
            ".pricing-card",
            { y: 36, opacity: 0, scale: 0.93 },
            {
              y: 0, opacity: 1, scale: 1,
              duration: 0.6, stagger: 0.13, ease: "power3.out",
              scrollTrigger: { trigger: ".pricing-grid", start: "top 83%" },
            },
          );

          // ── Pricing counter animation ─────────────────────────────────
          document.querySelectorAll(".pricing-card strong").forEach((el) => {
            const original = el.textContent ?? "";
            const numMatch = original.match(/[\d,.]+/);
            if (!numMatch) return;
            const rawNum = parseFloat(numMatch[0].replace(",", "."));
            if (isNaN(rawNum)) return;
            const before = original.slice(0, original.indexOf(numMatch[0]));
            const after = original.slice(original.indexOf(numMatch[0]) + numMatch[0].length);
            const obj = { val: 0 };
            ScrollTrigger.create({
              trigger: el,
              start: "top 85%",
              once: true,
              onEnter: () => {
                gsap.to(obj, {
                  val: rawNum,
                  duration: 1.2,
                  ease: "power2.out",
                  onUpdate: () => {
                    const formatted = Number.isInteger(rawNum)
                      ? Math.round(obj.val).toString()
                      : obj.val.toFixed(2).replace(".", numMatch[0].includes(",") ? "," : ".");
                    el.textContent = before + formatted + after;
                  },
                });
              },
            });
          });

          // ── FAQ: stagger items ────────────────────────────────────────
          gsap.fromTo(
            ".faq .section-title",
            { y: 20, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.5, ease: "power2.out",
              scrollTrigger: { trigger: ".faq", start: "top 85%" },
            },
          );
          gsap.fromTo(
            ".faq-item",
            { y: 22, opacity: 0 },
            {
              y: 0, opacity: 1,
              duration: 0.45, stagger: 0.07, ease: "power2.out",
              scrollTrigger: { trigger: ".faq-list", start: "top 85%" },
            },
          );

          // ── FAQ smooth accordion ──────────────────────────────────────
          document.querySelectorAll(".faq-item").forEach((item) => {
            const summary = item.querySelector("summary");
            const body = item.querySelector(".faq-body");
            if (!summary || !body) return;
            gsap.set(body, { height: 0, overflow: "hidden" });

            summary.addEventListener("click", (e) => {
              e.preventDefault();
              const isOpen = item.hasAttribute("open");
              if (isOpen) {
                gsap.to(body, {
                  height: 0,
                  duration: 0.35,
                  ease: "power2.inOut",
                  onComplete: () => item.removeAttribute("open"),
                });
              } else {
                item.setAttribute("open", "");
                gsap.fromTo(
                  body,
                  { height: 0 },
                  { height: "auto", duration: 0.45, ease: "power2.out" },
                );
              }
            });
          });

          // ── Waitlist card ─────────────────────────────────────────────
          gsap.fromTo(
            ".waitlist-card",
            { y: 52, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.7, ease: "power3.out",
              scrollTrigger: { trigger: ".waitlist-card", start: "top 85%" },
            },
          );

          // ── Magnetic buttons ──────────────────────────────────────────
          document.querySelectorAll(".button").forEach((btn) => {
            btn.addEventListener("mousemove", (e) => {
              const rect = btn.getBoundingClientRect();
              const x = (e.clientX - rect.left - rect.width / 2) * 0.32;
              const y = (e.clientY - rect.top - rect.height / 2) * 0.32;
              gsap.to(btn, { x, y, duration: 0.28, ease: "power2.out" });
            });
            btn.addEventListener("mouseleave", () => {
              gsap.to(btn, { x: 0, y: 0, duration: 0.55, ease: "elastic.out(1, 0.45)" });
            });
          });

          // ── Generic fallback .reveal (uncovered sections) ─────────────
          document
            .querySelectorAll("main section:not(.hero):not(.problem):not(.features):not(.feature-split):not(.flow):not(.pricing):not(.faq):not(.waitlist)")
            .forEach((section) => {
              const revealEls = section.querySelectorAll(".reveal");
              if (revealEls.length) {
                gsap.fromTo(
                  revealEls,
                  { y: 16, opacity: 0 },
                  {
                    y: 0, opacity: 1,
                    duration: 0.45, stagger: 0.06, ease: "power2.out",
                    scrollTrigger: { trigger: section, start: "top 85%" },
                  },
                );
              }
            });
        }

        // ── Waitlist form submit ─────────────────────────────────────────
        const waitlistForm = document.querySelector("[data-waitlist-form]");
        waitlistForm?.addEventListener("submit", async (event) => {
          event.preventDefault();
          const form = event.currentTarget as HTMLFormElement;
          const status = form.querySelector("[data-form-status]") as HTMLElement;
          const submitBtn = form.querySelector("button[type=submit]") as HTMLButtonElement;

          submitBtn.disabled = true;
          const originalText = submitBtn.textContent ?? "";
          submitBtn.textContent = "…";

          const data = Object.fromEntries(new FormData(form));

          try {
            const res = await fetch("/api/waitlist", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(data),
            });

            const json = await res.json();

            if (res.ok) {
              status.textContent = form.dataset.msgSuccess ?? "Done!";
              status.style.color = "";
              status.removeAttribute("hidden");
              form.reset();
            } else {
              const isDuplicate = json.error === "already_registered";
              status.textContent = isDuplicate
                ? (form.dataset.msgDuplicate ?? "Already registered.")
                : (form.dataset.msgError ?? "Error. Try again.");
              status.style.color = "var(--accent, #b8ff7a)";
              status.removeAttribute("hidden");
              submitBtn.disabled = false;
              submitBtn.textContent = originalText;
            }
          } catch {
            status.textContent = form.dataset.msgError ?? "Error. Try again.";
            status.style.color = "var(--accent, #b8ff7a)";
            status.removeAttribute("hidden");
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        });
      });

      // ── Features title: SplitText chars slide-in ────────────────
      document.fonts.ready.then(() => {
        gsap.set(".features-section-title", { opacity: 1 });
        const featuresSplit = SplitText.create(".features-section-title", { type: "chars,words" });
        gsap.from(featuresSplit.chars, {
          x: 150,
          opacity: 0,
          duration: 0.7,
          ease: "power4",
          stagger: 0.04,
          scrollTrigger: {
            trigger: ".features-section-title",
            start: "top 85%",
            once: true,
          },
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* Dark mode (default) */
  :root {
    color-scheme: dark;
    --bg: #07090d;
    --panel: #10141c;
    --panel-soft: rgba(255, 255, 255, 0.07);
    --text: #f7f3ea;
    --muted: #a7adba;
    --line: rgba(255, 255, 255, 0.12);
    --accent: #b8ff7a;
    --accent-2: #8bd3ff;
    --gold: #f5c76b;
    /* shadcn-compat RGB channels (dark) */
    --color-background: 7 9 13;
    --color-foreground: 247 243 234;
    --color-card: 16 20 28;
    --color-primary: 184 255 122;
    --color-muted: 22 28 40;
    --color-muted-fg: 167 173 186;
    --color-border: 255 255 255;
  }

  @keyframes floatOrb1 {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.18; }
    50% { transform: translateY(-28px) scale(1.05); opacity: 0.24; }
  }

  @keyframes floatOrb2 {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.14; }
    50% { transform: translateY(22px) scale(1.04); opacity: 0.20; }
  }

  @keyframes cursorPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.85; }
    50% { transform: translate(-50%, -50%) scale(1.4); opacity: 0.5; }
  }

  * {
    box-sizing: border-box;
  }

  html {
  }

  body {
    margin: 0;
    min-width: 320px;
    overflow-x: hidden;
    font-family: "Figtree", system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }

  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: min(800px, 70vw);
    height: min(600px, 60vh);
    background: radial-gradient(ellipse at center, rgba(139, 211, 255, 0.16), transparent 70%);
    pointer-events: none;
    z-index: 0;
    animation: floatOrb1 14s ease-in-out infinite;
    transform-origin: center center;
  }

  body::after {
    content: '';
    position: fixed;
    top: -10%;
    right: -5%;
    width: min(700px, 60vw);
    height: min(500px, 50vh);
    background: radial-gradient(ellipse at center, rgba(184, 255, 122, 0.12), transparent 70%);
    pointer-events: none;
    z-index: 0;
    animation: floatOrb2 18s ease-in-out infinite;
    transform-origin: center center;
  }

  .cursor-dot {
    position: fixed;
    top: 0;
    left: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: width 0.2s ease, height 0.2s ease, opacity 0.2s ease;
  }

  @media (hover: none) {
    .cursor-dot { display: none; }
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .noise {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.08;
    z-index: 1;
    background-image: linear-gradient(
      120deg,
      transparent,
      rgba(255, 255, 255, 0.18),
      transparent
    );
    mix-blend-mode: overlay;
  }

  .section-pad {
    position: relative;
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 120px 0;
    --section-glow-opacity: 0;
  }

  .section-pad::before {
    position: absolute;
    inset: 10% auto auto 50%;
    z-index: -1;
    width: min(680px, 80vw);
    height: 280px;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(139, 211, 255, 0.1),
      transparent 68%
    );
    content: "";
    opacity: var(--section-glow-opacity);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .hero {
    position: relative;
    overflow: hidden;
    width: 100%;
    min-height: 100vh;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
    padding-top: 140px;
    padding-bottom: 80px;
    perspective: 1000px;
    position: relative;
    z-index: 1;
  }

  .hero-bg-shader {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.75;
  }

  .hero-content,
  .hero-mockup-wrap {
    position: relative;
    z-index: 1;
  }

  .hero-content {
    width: 100%;
    max-width: 900px;
    text-align: center;
    margin-bottom: 40px;
  }

  .hero-copy {
    width: 100%;
  }

  .reveal {
    opacity: 0;
  }

  /* hero-title hidden state — managed independently (not via .reveal) */
  .hero-title {
    opacity: 0;
  }

  .device-mockup {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .hero-title,
    .problem-title,
    .device-mockup {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  /* spring-scale-in word units */
  .hero-title .text-animation-unit {
    display: inline-block;
    white-space: pre;
    backface-visibility: hidden;
    transform-origin: 50% 55%;
    will-change: transform, opacity;
  }


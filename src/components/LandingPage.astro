const panelItems = copy.features.map(([title, description], i) => {
  const mediaMap = [
    "/mockups/Categorias.png",
    "/mockups/Control_notas.mov",
    "/mockups/Pase_de_ronda.png",
    "/mockups/Importacion_CSV.png",
    "/mockups/Ensayos_y_actuaciones.png",
    "/mockups/Calendario_gobal.png",
  ];
  return { title, content: mediaMap[i] || "", description };
});

const lang = locale === "es" ? "es" : "en";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{copy.metaTitle}</title>
    <meta name="description" content={copy.metaDescription} />
    <link rel="canonical" href={locale === "es" ? "/" : "/en/"} />
    <link rel="alternate" hreflang="es" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Figtree:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="cursor-dot" aria-hidden="true"></div>

    <LandingHeader locale={locale} copy={copy} />

    <main>
      <HeroSection hero={copy.hero} />
      <ProblemSection problem={copy.problem} />
      <ScrollTextSection text={copy.scrollText} />
      <section class="section-pad">
        <h2 class="section-title centered reveal">{copy.featuresTitle}</h2>
        <FeaturesWithPanel items={panelItems} client:only="react" />
      </section>
      <ScreenSplitSection
        section={copy.categories}
        imageSrc="/mockups/Creacion_concurso.mov"
        imageAlt="Creación de concurso"
        cta={copy.hero.primary}
        isVideo
      />
      <ScreenSplitSection
        section={copy.judges}
        imageSrc="/mockups/Control_notas.mov"
        imageAlt="Control de notas"
        reverse
        cta={copy.hero.primary}
        isVideo
      />
      <FlowSection flow={copy.flow} />
      <ScreenSplitSection
        section={copy.audit}
        imageSrc="/screens/audit.svg"
        imageAlt="Audit trail placeholder"
        cta={copy.hero.primary}
      />
      <ScreenSplitSection
        section={copy.calendar}
        imageSrc="/screens/calendar.svg"
        imageAlt="Calendar placeholder"
        reverse
        cta={copy.hero.primary}
      />
      <PricingSection pricing={copy.pricing} />
      <FaqSection title={copy.faqTitle} faqs={copy.faqs} />
      <WaitlistSection waitlist={copy.waitlist} />
    </main>

    <LandingFooter locale={locale} />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      window.addEventListener("load", () => {
        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

        // ── Scroll progress bar (always active) ─────────────────────────
        gsap.to(".scroll-progress", {
          scaleX: 1,
          ease: "none",
          scrollTrigger: {
            trigger: document.documentElement,
            start: "top top",
            end: "bottom bottom",
            scrub: 0.25,
          },
        });

        if (!reducedMotion) {
          // ── Cursor glow dot ──────────────────────────────────────────
          const cursorDot = document.querySelector(".cursor-dot");
          if (cursorDot) {
            window.addEventListener("mousemove", (e) => {
              gsap.to(cursorDot, {
                x: e.clientX,
                y: e.clientY,
                duration: 0.18,
                ease: "power2.out",
              });
            });
            document.addEventListener("mouseleave", () => {
              gsap.to(cursorDot, { opacity: 0, duration: 0.2 });
            });
            document.addEventListener("mouseenter", () => {
              gsap.to(cursorDot, { opacity: 1, duration: 0.2 });
            });
          }

          // ── Hero: dramatic entrance timeline ─────────────────────────
          const heroTl = gsap.timeline({ delay: 0.15 });
          heroTl
            .fromTo(
              ".eyebrow",
              { x: -28, opacity: 0 },
              { x: 0, opacity: 1, duration: 0.55, ease: "power3.out" },
            )
            .fromTo(
              ".hero-title",
              { y: 64, opacity: 0, rotateX: 7 },
              { y: 0, opacity: 1, rotateX: 0, duration: 0.95, ease: "power3.out" },
              "-=0.2",
            )
            .fromTo(
              ".hero-body",
              { y: 28, opacity: 0, filter: "blur(5px)" },
              { y: 0, opacity: 1, filter: "blur(0px)", duration: 0.65, ease: "power2.out" },
              "-=0.55",
            )
            .fromTo(
              ".hero-actions",
              { y: 20, opacity: 0, scale: 0.96 },
              { y: 0, opacity: 1, scale: 1, duration: 0.5, ease: "back.out(1.7)" },
              "-=0.45",
            )
            .fromTo(
              ".discount-note",
              { y: 12, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.4, ease: "power2.out" },
              "-=0.35",
            );

          // ── Hero device mockups ───────────────────────────────────────
          const deviceEntrances = [
            { x: -24, y: 48, rotate: -2.5 },
            { x: 0, y: 64, scale: 0.96 },
            { x: 24, y: 48, rotate: 2.5 },
          ];
          const devices = document.querySelectorAll(".device-mockup");
          devices.forEach((device, i) => {
            const from = deviceEntrances[i] ?? { y: 40 };
            gsap.fromTo(
              device,
              { ...from, opacity: 0 },
              {
                x: 0, y: 0, rotate: 0, scale: 1, opacity: 1,
                duration: 1.0,
                delay: 0.55 + i * 0.12,
                ease: "power3.out",
              },
            );

            const direction = i === 0 ? -1 : i === 2 ? 1 : 0;
            gsap.to(device, {
              y: `+=${direction * 22}`,
              scrollTrigger: {
                trigger: ".hero",
                start: "top top",
                end: "bottom top",
                scrub: true,
              },
            });
          });

          // ── Problem: header + cards staggered ────────────────────────
          gsap.fromTo(
            ".problem-header .reveal",
            { y: 20, opacity: 0 },
            {
              y: 0, opacity: 1,
              duration: 0.5, stagger: 0.07, ease: "power2.out",
              scrollTrigger: { trigger: ".problem-header", start: "top 85%" },
            },
          );
          gsap.fromTo(
            ".glass-card",
            { y: 44, opacity: 0, scale: 0.95 },
            {
              y: 0, opacity: 1, scale: 1,
              duration: 0.55, stagger: 0.1, ease: "power3.out",
              scrollTrigger: { trigger: ".problem-cards", start: "top 82%" },
            },
          );

          // ── ScreenSplit: copy slides in, media clip-path reveal ───────
          document.querySelectorAll(".feature-split").forEach((split) => {
            const isReverse = split.hasAttribute("data-reverse");
            const copy = split.querySelector("[data-split-copy]");
            const media = split.querySelector("[data-split-media]");

            if (copy) {
              gsap.fromTo(
                copy.querySelectorAll(".reveal"),
                { x: isReverse ? 44 : -44, opacity: 0 },
                {
                  x: 0, opacity: 1,
                  duration: 0.65, stagger: 0.09, ease: "power3.out",
                  scrollTrigger: { trigger: copy, start: "top 82%" },
                },
              );
            }

            if (media) {
              const clipStart = isReverse ? "inset(0 0% 0 100%)" : "inset(0 100% 0 0%)";
              gsap.fromTo(
                media,
                { clipPath: clipStart, opacity: 0.4 },
                {
                  clipPath: "inset(0 0% 0 0%)",
                  opacity: 1,
                  duration: 0.9,
                  ease: "power3.inOut",
                  scrollTrigger: { trigger: media, start: "top 85%" },
                },
              );
            }
          });

          // ── Flow section ──────────────────────────────────────────────
          gsap.fromTo(
            ".flow-header .reveal",
            { y: 24, opacity: 0 },
            {
              y: 0, opacity: 1,
              duration: 0.5, stagger: 0.08, ease: "power2.out",
              scrollTrigger: { trigger: ".flow-header", start: "top 85%" },
            },
          );
          gsap.fromTo(
            ".flow-cards-wrapper",
            { y: 36, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.6, ease: "power2.out",
              scrollTrigger: { trigger: ".flow-cards-wrapper", start: "top 88%" },
            },
          );

          // ── Pricing cards: stagger scale-up ───────────────────────────
          gsap.fromTo(
            ".pricing .section-title",
            { y: 24, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.55, ease: "power2.out",
              scrollTrigger: { trigger: ".pricing", start: "top 85%" },
            },
          );
          gsap.fromTo(
            ".pricing-card",
            { y: 36, opacity: 0, scale: 0.93 },
            {
              y: 0, opacity: 1, scale: 1,
              duration: 0.6, stagger: 0.13, ease: "power3.out",
              scrollTrigger: { trigger: ".pricing-grid", start: "top 83%" },
            },
          );

          // ── Pricing counter animation ─────────────────────────────────
          document.querySelectorAll(".pricing-card strong").forEach((el) => {
            const original = el.textContent ?? "";
            const numMatch = original.match(/[\d,.]+/);
            if (!numMatch) return;
            const rawNum = parseFloat(numMatch[0].replace(",", "."));
            if (isNaN(rawNum)) return;
            const before = original.slice(0, original.indexOf(numMatch[0]));
            const after = original.slice(original.indexOf(numMatch[0]) + numMatch[0].length);
            const obj = { val: 0 };
            ScrollTrigger.create({
              trigger: el,
              start: "top 85%",
              once: true,
              onEnter: () => {
                gsap.to(obj, {
                  val: rawNum,
                  duration: 1.2,
                  ease: "power2.out",
                  onUpdate: () => {
                    const formatted = Number.isInteger(rawNum)
                      ? Math.round(obj.val).toString()
                      : obj.val.toFixed(2).replace(".", numMatch[0].includes(",") ? "," : ".");
                    el.textContent = before + formatted + after;
                  },
                });
              },
            });
          });

          // ── FAQ: stagger items ────────────────────────────────────────
          gsap.fromTo(
            ".faq .section-title",
            { y: 20, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.5, ease: "power2.out",
              scrollTrigger: { trigger: ".faq", start: "top 85%" },
            },
          );
          gsap.fromTo(
            ".faq-item",
            { y: 22, opacity: 0 },
            {
              y: 0, opacity: 1,
              duration: 0.45, stagger: 0.07, ease: "power2.out",
              scrollTrigger: { trigger: ".faq-list", start: "top 85%" },
            },
          );

          // ── FAQ smooth accordion ──────────────────────────────────────
          document.querySelectorAll(".faq-item").forEach((item) => {
            const summary = item.querySelector("summary");
            const body = item.querySelector(".faq-body");
            if (!summary || !body) return;
            gsap.set(body, { height: 0, overflow: "hidden" });

            summary.addEventListener("click", (e) => {
              e.preventDefault();
              const isOpen = item.hasAttribute("open");
              if (isOpen) {
                gsap.to(body, {
                  height: 0,
                  duration: 0.35,
                  ease: "power2.inOut",
                  onComplete: () => item.removeAttribute("open"),
                });
              } else {
                item.setAttribute("open", "");
                gsap.fromTo(
                  body,
                  { height: 0 },
                  { height: "auto", duration: 0.45, ease: "power2.out" },
                );
              }
            });
          });

          // ── Waitlist card ─────────────────────────────────────────────
          gsap.fromTo(
            ".waitlist-card",
            { y: 52, opacity: 0 },
            {
              y: 0, opacity: 1, duration: 0.7, ease: "power3.out",
              scrollTrigger: { trigger: ".waitlist-card", start: "top 85%" },
            },
          );

          // ── Magnetic buttons ──────────────────────────────────────────
          document.querySelectorAll(".button").forEach((btn) => {
            btn.addEventListener("mousemove", (e) => {
              const rect = btn.getBoundingClientRect();
              const x = (e.clientX - rect.left - rect.width / 2) * 0.32;
              const y = (e.clientY - rect.top - rect.height / 2) * 0.32;
              gsap.to(btn, { x, y, duration: 0.28, ease: "power2.out" });
            });
            btn.addEventListener("mouseleave", () => {
              gsap.to(btn, { x: 0, y: 0, duration: 0.55, ease: "elastic.out(1, 0.45)" });
            });
          });

          // ── Generic fallback .reveal (uncovered sections) ─────────────
          document
            .querySelectorAll("main section:not(.hero):not(.problem):not(.features):not(.feature-split):not(.flow):not(.pricing):not(.faq):not(.waitlist)")
            .forEach((section) => {
              const revealEls = section.querySelectorAll(".reveal");
              if (revealEls.length) {
                gsap.fromTo(
                  revealEls,
                  { y: 16, opacity: 0 },
                  {
                    y: 0, opacity: 1,
                    duration: 0.45, stagger: 0.06, ease: "power2.out",
                    scrollTrigger: { trigger: section, start: "top 85%" },
                  },
                );
              }
            });
        }

        // ── Waitlist form submit ─────────────────────────────────────────
        document
          .querySelector("[data-waitlist-form]")
          ?.addEventListener("submit", (event) => {
            event.preventDefault();
            document
              .querySelector("[data-form-status]")
              ?.removeAttribute("hidden");
          });
      });
    </script>
  </body>
</html>


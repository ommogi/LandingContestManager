---
import { FlowCardStack } from './FlowCardStack.jsx';

interface Props {
  flow: {
    title: string;
    steps: [string, string, string][];
  };
}

const { flow } = Astro.props;
---

<section id="flujo" class="flow section-pad">
  <div class="flow-header">
    <p class="eyebrow reveal">Workflow</p>
    <h2 class="section-title reveal">{flow.title}</h2>
  </div>
  <div class="flow-cards-wrapper reveal">
    <div class="flow-cards">
      <FlowCardStack steps={flow.steps} client:load />
    </div>
    <div class="flow-vignette" aria-hidden="true"></div>
  </div>
</section>

<style>
  .flow-cards-wrapper {
    position: relative;
  }

  .flow-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: 
      linear-gradient(to right, var(--bg) 0%, transparent 8%, transparent 92%, var(--bg) 100%),
      linear-gradient(to bottom, transparent 75%, var(--bg) 100%),
      linear-gradient(to top, transparent 80%, var(--bg) 100%);
  }
</style>

---
const cards = [
  {
    title: "Sin duplicados",
    description: "Una fuente de verdad para cada categoría y ronda.",
    icon: "check-circle",
  },
  {
    title: "Control administrativo",
    description: "El organizador decide cuándo avanzar y cuántos pasan.",
    icon: "shield",
  },
  {
    title: "Historial visible",
    description: "Los cambios relevantes quedan registrados para consulta.",
    icon: "eye",
  },
];

const ICONS: Record<string, string> = {
  "check-circle": `<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>`,
  "shield": `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  "eye": `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>`,
};
---

<div class="feature-cards-grid">
  {cards.map((card, i) => (
    <div class="feature-card" data-index={i}>
      <div class="grid-pattern-wrap" aria-hidden="true">
        <svg class="grid-svg" aria-hidden="true">
          <defs>
            <pattern id={`pattern-card-${i}`} width="20" height="20" patternUnits="userSpaceOnUse" x="-12" y="4">
              <path d="M.5 20V.5H20" fill="none" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" stroke-width="0" fill={`url(#pattern-card-${i})`} />
        </svg>
      </div>
      <svg
        class="card-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={ICONS[card.icon]}
      />
      <h3 class="card-title">{card.title}</h3>
      <p class="card-desc">{card.description}</p>
    </div>
  ))}
</div>

<style>
  .feature-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 900px;
    margin: 0 auto;
  }

  .feature-card {
    position: relative;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    overflow: hidden;
    padding: 24px;
    text-align: left;
  }

  .grid-pattern-wrap {
    pointer-events: none;
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    mask-image: linear-gradient(white, transparent);
    -webkit-mask-image: linear-gradient(white, transparent);
  }

  .grid-svg {
    fill: rgba(255, 255, 255, 0.05);
    stroke: rgba(255, 255, 255, 0.25);
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    mix-blend-mode: overlay;
  }

  .card-icon {
    color: rgba(255, 255, 255, 0.75);
    width: 28px;
    height: 28px;
    display: block;
  }

  .card-title {
    margin: 32px 0 12px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .card-desc {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .feature-cards-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 480px) and (max-width: 768px) {
    .feature-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

---
const cards = [
  {
    title: "Sin duplicados",
    description: "Una fuente de verdad para cada categoría y ronda.",
    icon: "check-circle",
  },
  {
    title: "Control administrativo",
    description: "El organizador decide cuándo avanzar y cuántos pasan.",
    icon: "shield",
  },
  {
    title: "Historial visible",
    description: "Los cambios relevantes quedan registrados para consulta.",
    icon: "eye",
  },
];

const ICONS: Record<string, string> = {
  "check-circle": `<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>`,
  "shield": `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  "eye": `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>`,
};
---

<div class="feature-cards-grid">
  {cards.map((card, i) => (
    <div class="feature-card" data-index={i}>
      <!-- grid pattern top-right corner -->
      <div class="grid-corner" aria-hidden="true">
        <svg class="grid-svg" aria-hidden="true">
          <defs>
            <pattern id={`pat-${i}`} width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill={`url(#pat-${i})`} />
        </svg>
      </div>

      <svg
        class="card-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={ICONS[card.icon]}
      />
      <h3 class="card-title">{card.title}</h3>
      <p class="card-desc">{card.description}</p>
    </div>
  ))}
</div>

<style>
  .feature-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 900px;
    margin: 0 auto;
  }

  .feature-card {
    position: relative;
    background: rgba(255, 255, 255, 0.015);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 28px 24px 32px;
    text-align: left;
    overflow: hidden;
  }

  /* grid in top-right corner, fades toward bottom-left */
  .grid-corner {
    position: absolute;
    top: 0;
    right: 0;
    width: 55%;
    height: 55%;
    pointer-events: none;
    mask-image: radial-gradient(ellipse at top right, white 10%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at top right, white 10%, transparent 75%);
  }

  .grid-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .card-icon {
    color: rgba(255, 255, 255, 0.7);
    width: 24px;
    height: 24px;
    display: block;
    position: relative;
    z-index: 1;
  }

  .card-title {
    margin: 28px 0 10px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    position: relative;
    z-index: 1;
  }

  .card-desc {
    font-size: 0.85rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .feature-cards-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 480px) and (max-width: 768px) {
    .feature-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

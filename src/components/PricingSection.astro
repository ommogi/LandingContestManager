---
import PricingHighlight from './PricingHighlight';

const ICON_KEYS = ['ticket', 'clipboard', 'shield'] as const;

const rawCards: [string, string, string][] = [
  ["Tickets",                  "1 euro por ticket",      "Cada inscripción creada o importada mediante CSV consume un ticket."],
  ["Inscripciones gestionadas","5% por inscripción",     "Si usas la gestión de inscripciones de la aplicación, pagas una comisión del 5%."],
  ["Lista blanca",             "5% de descuento",        "Los primeros interesados reciben un 5% de descuento en su primera compra."],
];

const cards = rawCards.map(([cardTitle, price, text], i) => ({
  title: cardTitle,
  description: [price, text],
  iconKey: ICON_KEYS[i],
}));
---

<section id="precios" class="pricing section-pad">
  <h2 class="title section-title centered no-margin">
    <span class="pay-highlight">Pay as you go</span>
  </h2>
  <h2 class="title section-title centered reveal">Pensado para concursos de cualquier tamaño.</h2>
  <PricingHighlight cards={cards} client:visible />
</section>

<style>
  .title {
    font-size: clamp(1.8rem, 3.5vw, 3.8rem);
    font-weight: 400;
  }
  .no-margin {
    margin-bottom: 20px !important;
  }
  .pay-highlight {
    background: linear-gradient(to right, #3b82f6, #a855f7);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    background-position: left center;
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 0.5rem;
    color: #ffffff;
    transition: background-size 2s ease-in-out;
  }
  .pay-highlight.in-view {
    background-size: 100% 100%;
  }
</style>

<script>
  const el = document.querySelector('.pay-highlight');
  if (el) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('in-view');
          observer.disconnect();
        }
      },
      { threshold: 0.5 }
    );
    observer.observe(el);
  }
</script>

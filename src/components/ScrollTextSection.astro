---
import ScrollReveal from './ui/scroll-reveal';

interface Props {
  text: string;
}

const { text } = Astro.props;
---

<section class="scroll-text-section">
  <ScrollReveal text={text} client:load />
</section>

<style>
  .scroll-text-section {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    padding: 4rem 2rem;
    box-sizing: border-box;
    position: relative;
  }
</style>
---
import StaggeredMenu from "./StaggeredMenu.jsx";

const navItems = [
  { label: "Problema",                    ariaLabel: "Problema",                    link: "#problema" },
  { label: "Funciones",                   ariaLabel: "Funciones",                   link: "#funciones" },
  { label: "Flujo",                       ariaLabel: "Flujo",                       link: "#flujo" },
  { label: "Precios",                     ariaLabel: "Precios",                     link: "#precios" },
  { label: "FAQ",                         ariaLabel: "FAQ",                         link: "#faq" },
  { label: "Apuntarme a la lista blanca", ariaLabel: "Apuntarme a la lista blanca", link: "#lista-blanca" },
];
---

<StaggeredMenu
  client:load
  position="right"
  items={navItems}
  displaySocials={false}
  displayItemNumbering={true}
  menuButtonColor="#f7f3ea"
  openMenuButtonColor="#111111"
  changeMenuColorOnOpen={true}
  colors={["#b8ff7a", "#8bd3ff"]}
  accentColor="#5227ff"
  logoUrl="/contest-manager-logo.png"
  isFixed={true}
  closeOnClickAway={true}
/>

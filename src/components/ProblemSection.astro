---
import { FeatureCardsGrid } from './FeatureCardsGrid';

interface Props {
  problem: {
    title: string;
    body: string;
    cards: [string, string][];
  };
}

const { problem } = Astro.props;
---

<section id="problema" class="problem section-pad">
  <div class="problem-header">
    <p class="eyebrow reveal">Deja atrás Excel</p>
    <h2 class="section-title problem-title reveal">{problem.title}</h2>
    <p class="problem-body reveal">{problem.body}</p>
  </div>
  
  <div class="reveal">
    <FeatureCardsGrid cards={problem.cards} client:load />
  </div>
</section>

<style>
  .problem {
    text-align: center;
  }

  .problem-header {
    max-width: 800px;
    margin: 0 auto 48px;
  }

  .problem-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin: 16px 0 24px;
    line-height: 1.1;
  }

  .problem-body {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .problem-title {
      font-size: clamp(1.75rem, 6vw, 2.5rem);
    }
  }
</style>
